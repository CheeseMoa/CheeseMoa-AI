# CheeseMoa-AI 워커 환경변수 예시 — 실값을 채워 .env로 복사해서 사용한다 (.env는 커밋 금지).
# 큐 URL·버킷명은 아직 미정(feature-spec §10 #7): 아래 placeholder는 형식 예시일 뿐이다.

# ── AWS 주소 (필수 — 미설정 시 워커가 기동 시점에 누락 필드를 나열하며 실패) ──
# 단일 FIFO 인바운드 큐 (classify/feedback/delete 공용, messageGroupId=event_id, ADR-007)
INBOUND_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/000000000000/cheesemoa-classify-request.fifo
RESULT_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/000000000000/cheesemoa-classify-result
EMBEDDINGS_BUCKET=cheesemoa-embeddings-placeholder
IMAGES_BUCKET=cheesemoa-images-placeholder
AWS_REGION=ap-northeast-2

# 분류 진행률(progress) 발행 큐 (CHMO-274, 선택). 설정하면 classify 처리 중 처리 장수를 이 큐로
# 여러 번 흘려보내 백엔드가 분류 진행바를 그린다. 미설정이면 진행률 발행 비활성 — 큐를 만들기
# 전에 워커를 배포해도 안전하게 뜬다. 표준 큐 권장(진행률은 유실돼도 되는 부수 신호).
#PROGRESS_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/000000000000/cheesemoa-classify-progress

# ── SQS 소비 파라미터 (선택 — 기본값 있음) ──────────────────────────────────
# 인바운드 큐 인프라 설정 메모:
#  - visibility timeout은 대량 classify(이미지 수백 장 fetch+detect+embed)가 끝나기 전에
#    만료되지 않게 넉넉히 잡는다 (권장 15분). 하트비트(ChangeMessageVisibility)는 post-MVP.
#  - redrive policy의 maxReceiveCount는 SQS_MAX_RECEIVE_COUNT와 반드시 일치시킨다 (DLQ: classify-dlq).
#SQS_WAIT_TIME_SECONDS=20
#SQS_MAX_RECEIVE_COUNT=3

# ── 모델 파일 로컬 오버라이드 (선택 — 미설정 시 자동 다운로드) ──
# YuNet/AuraFace는 Hugging Face Hub, 눈감음 CNN(open-closed-eye-0001)은 OpenVINO 스토리지 URL에서 받는다.
# URL 다운로드 캐시 위치는 기본 ~/.cache/cheesemoa (CHEESEMOA_CACHE_DIR로 오버라이드 가능).
#YUNET_MODEL_PATH=C:\models\face_detection_yunet_2023mar.onnx
#AURAFACE_MODEL_PATH=C:\models\glintr100.onnx
#EYE_MODEL_PATH=C:\models\open_closed_eye.onnx

# ── 추론 스레드 (선택 — 기본 0 = 가용 코어 수 자동 감지, 권장) ──
# 코어 수보다 크게 잡으면 오버서브스크립션으로 급격히 느려진다. t4g.small(2코어) 실측에서 8스레드는
# 2스레드 대비 임베딩이 6배 느렸다 (docs/guides/worker-scaling-and-performance.md §7).
#ORT_NUM_THREADS=0

# ── 클러스터링 임계값 (선택 — 기본값은 PoC 검증 레시피, feature-spec §10 #3·#4) ──
#CLUSTER_MIN_CLUSTER_SIZE=2
#CLUSTER_MIN_SAMPLES=2
#CLUSTER_SELECTION_EPSILON=0.15
#CLUSTER_MIN_MATCH_JACCARD=0.0
#CLUSTER_MERGE_CENTROID_SIMILARITY=0.55
#CLUSTER_MERGE_FACEPAIR_FLOOR=0.475
#CLUSTER_RESCUE_SIMILARITY=0.6
#CLUSTER_MIN_MEMBERSHIP_SIMILARITY=0.4
#CLUSTER_MIN_MEMBERSHIP_MARGIN=0.05
# 저신뢰 분리의 회색지대 face-pair 재확인 (ADR-020): LOO centroid가 바닥(0.4)~ceiling 사이인 멤버는
# 클러스터 내 최강 쌍이 floor 미만이면(동일인 증거 부재) 남남 부착으로 보고 축출. 둘 중 하나라도 0이면 비활성.
#CLUSTER_EVICT_GRAY_CEILING=0.46
#CLUSTER_EVICT_FACEPAIR_FLOOR=0.45
#CLUSTER_BLOB_PROMOTE_SIMILARITY=0.45
#CLUSTER_BLOB_PROMOTE_FLOOR=0.4

# ── 입력 품질 교정 (선택 — 2026-07-14 리뷰: 정렬 안티에일리어싱 + 랜드마크 2단계 정제) ──
# 같은 얼굴 임베딩이 흔들리던 파이프라인 노이즈를 잡는 교정 토글. 운영 이슈 시 여기서 끈다.
#ALIGN_ANTIALIAS=true
#DETECT_MAX_SIDE=2000
#DETECT_REFINE_LANDMARKS=true
#DETECT_REFINE_NORM_FACE_WIDTH=224
#DETECT_REFINE_MARGIN_RATIO=0.75
# 배경 인물 필터 (ADR-013): 얼굴 bbox 폭이 이미지 긴 변의 2.5% 미만이면 검출 단계에서 버린다 —
# 멀리 배경에 찍힌 행인이 반복 등장해 앨범을 만드는 것 방지. 0 = 비활성.
#DETECT_MIN_FACE_REL_WIDTH=0.025
# 대형 오검출 결합 필터 (ADR-015): 얼굴 score가 이 값 미만 AND 종횡비(폭/높이)가 아래 값 미만이면
# 검출 단계에서 버린다 — 팔짱 낀 팔·조형물 등 진짜 얼굴 크기의 오검출 제거. 둘 중 하나라도 0이면 비활성.
#DETECT_FP_SCORE_THRESHOLD=0.78
#DETECT_FP_ASPECT_THRESHOLD=0.70
# 대형 근접 얼굴 재검출 회복 (ADR-017): rel_w(bbox폭/긴변)가 이 값 이상인 저score 얼굴을 정규 크기로
# 재검출해 재검출 score가 아래 값 이상이면 되살린다 — YuNet이 초근접 대형 얼굴에 낮은 score를 줘
# 공통 사진첩으로 빠지던 문제. 둘 중 하나라도 0이면 비활성.
#DETECT_BIG_FACE_REL_WIDTH=0.30
#DETECT_BIG_FACE_REDETECT_SCORE=0.80

# ── 품질 게이트 임계값 (선택 — 눈감음/흔들림. 기본값은 초기값이며 face-test 실측 보정 필요) ──
#QUALITY_BLUR_THRESHOLD=100.0
#QUALITY_WHOLE_IMAGE_BLUR_THRESHOLD=100.0
# 최대 얼굴 폭 대비 이 비율 미만인 얼굴은 배경 인물로 보고 blur 판정 제외 (아웃포커스 오탐 방지). 0 = 비활성.
#QUALITY_BLUR_MAIN_FACE_RATIO=0.5
# 얼굴 미검출 fallback의 방향성 블러 검출 (ADR 014) — 그라디언트 방향 쏠림이 임계 이상이고
# 정규화 variance가 상한 미만이면 흔들림. 쏠림 임계 0 = 비활성.
#QUALITY_SHAKE_COHERENCE_THRESHOLD=0.35
#QUALITY_SHAKE_MAX_NORM_VARIANCE=60.0
# variance 흔들림 판정의 재확인 게이트 — 전체 이미지 방향 쏠림이 이 값 미만이면 손떨림이 아니라
# 원판이 소프트한 사진(옛날 인화 재촬영)으로 보고 해제 (event 50 실측). 0 = 비활성.
#QUALITY_SHAKE_COHERENCE_FLOOR=0.35
# 게이트 면제(fallback 한정) — 전체 variance가 이 값 미만이면 잔결 붕괴라 쏠림과 무관하게 흔들림
# 확정. 고스팅형 손떨림은 쏠림이 낮게 나온다 (event 55 실측). 0 = 비활성.
#QUALITY_WHOLE_IMAGE_COLLAPSE_VARIANCE=40.0
# 붕괴 면제의 얼굴 경로 확장 (ADR 018 §보강 2) — blurry 얼굴 폭이 긴 변 대비 이 비율 이상(대형 주
# 인물)이면 얼굴 경로에서도 위 붕괴 면제를 적용. 고스팅 대형 셀피가 검출 회복으로 얼굴 경로에 빠져
# 게이트에 오해제되던 문제 (event 64 실측). 0 = 비활성.
#QUALITY_COLLAPSE_FACE_REL_WIDTH=0.22
#QUALITY_EYE_CLOSED_CONFIDENCE=0.85
#QUALITY_EYE_BOX_PX=24
# 눈감음 판정 자격 게이트 (ADR 019) — bbox 짧은 변이 아래 값 미만이면 정보 부족(그림·옆얼굴 오탐),
# 눈/볼 밝기 비가 아래 상한 초과면 눈 자리가 피부가 아님(고글 반사·마스크 가림)으로 보고 미판정. 0 = 비활성.
#QUALITY_MIN_EYE_FACE_PX=64
#QUALITY_EYE_CHEEK_BRIGHTNESS_CEILING=1.4

#LOG_LEVEL=INFO
