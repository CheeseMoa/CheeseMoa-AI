# CheeseMoa-AI 워커 환경변수 예시 — 실값을 채워 .env로 복사해서 사용한다 (.env는 커밋 금지).
# 큐 URL·버킷명은 아직 미정(feature-spec §10 #7): 아래 placeholder는 형식 예시일 뿐이다.

# ── AWS 주소 (필수 — 미설정 시 워커가 기동 시점에 누락 필드를 나열하며 실패) ──
# 단일 FIFO 인바운드 큐 (classify/feedback/delete 공용, messageGroupId=event_id, ADR-007)
INBOUND_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/000000000000/cheesemoa-classify-request.fifo
RESULT_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/000000000000/cheesemoa-classify-result
EMBEDDINGS_BUCKET=cheesemoa-embeddings-placeholder
IMAGES_BUCKET=cheesemoa-images-placeholder
AWS_REGION=ap-northeast-2

# 분류 진행률(progress) 발행 큐 (CHMO-274, 선택). 설정하면 classify 처리 중 처리 장수를 이 큐로
# 여러 번 흘려보내 백엔드가 분류 진행바를 그린다. 미설정이면 진행률 발행 비활성 — 큐를 만들기
# 전에 워커를 배포해도 안전하게 뜬다. 표준 큐 권장(진행률은 유실돼도 되는 부수 신호).
#PROGRESS_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/000000000000/cheesemoa-classify-progress

# ── SQS 소비 파라미터 (선택 — 기본값 있음) ──────────────────────────────────
# 인바운드 큐 인프라 설정 메모:
#  - visibility timeout은 대량 classify(이미지 수백 장 fetch+detect+embed)가 끝나기 전에
#    만료되지 않게 넉넉히 잡는다 (권장 15분). 하트비트(ChangeMessageVisibility)는 post-MVP.
#  - redrive policy의 maxReceiveCount는 SQS_MAX_RECEIVE_COUNT와 반드시 일치시킨다 (DLQ: classify-dlq).
#SQS_WAIT_TIME_SECONDS=20
#SQS_MAX_RECEIVE_COUNT=3

# ── 모델 파일 로컬 오버라이드 (선택 — 미설정 시 자동 다운로드) ──
# YuNet/AuraFace는 Hugging Face Hub, 눈감음 CNN(open-closed-eye-0001)은 OpenVINO 스토리지 URL에서 받는다.
# URL 다운로드 캐시 위치는 기본 ~/.cache/cheesemoa (CHEESEMOA_CACHE_DIR로 오버라이드 가능).
#YUNET_MODEL_PATH=C:\models\face_detection_yunet_2023mar.onnx
#AURAFACE_MODEL_PATH=C:\models\glintr100.onnx
#EYE_MODEL_PATH=C:\models\open_closed_eye.onnx
#FACELANDMARKER_MODEL_PATH=C:\models\face_landmarker.task

# ── 추론 스레드 (선택 — 기본 0 = 가용 코어 수 자동 감지, 권장) ──
# 코어 수보다 크게 잡으면 오버서브스크립션으로 급격히 느려진다. t4g.small(2코어) 실측에서 8스레드는
# 2스레드 대비 임베딩이 6배 느렸다 (docs/guides/worker-scaling-and-performance.md §7).
#ORT_NUM_THREADS=0

# ── 클러스터링 임계값 (선택 — 기본값은 PoC 검증 레시피, feature-spec §10 #3·#4) ──
#CLUSTER_MIN_CLUSTER_SIZE=2
#CLUSTER_MIN_SAMPLES=2
#CLUSTER_SELECTION_EPSILON=0.15
#CLUSTER_MIN_MATCH_JACCARD=0.0
#CLUSTER_MERGE_CENTROID_SIMILARITY=0.55
#CLUSTER_MERGE_FACEPAIR_FLOOR=0.475
# 병합 승인 검사 (ADR-024): 컴포넌트 '현재 전체 멤버' 재평가(재계산 centroid + 전체 face-pair 평균).
# false = 구 동작(병합 전 파편 스냅샷 쌍 완전 연결) — 2얼굴 파편 노이즈로 같은 인물 앨범이 쪼개질 수 있음.
#CLUSTER_MERGE_COMPONENT_LINKAGE=true
#CLUSTER_RESCUE_SIMILARITY=0.6
# margin 구제 (2026-07-23 실측): 절대 유사도는 낮지만(옆얼굴·역광·모션) 2위 군집 대비 top1/top2 배율이
# 큰 노이즈 얼굴을 top1에 편입. floor 0 = 비활성(기본) — 실 이벤트 적대 검증 전 실험 전용.
#CLUSTER_MARGIN_RESCUE_FLOOR=0.0
#CLUSTER_MARGIN_RESCUE_RATIO=1.7
#CLUSTER_MIN_MEMBERSHIP_SIMILARITY=0.4
#CLUSTER_MIN_MEMBERSHIP_MARGIN=0.05
# 저신뢰 분리의 회색지대 face-pair 재확인 (ADR-020): LOO centroid가 바닥(0.4)~ceiling 사이인 멤버는
# 클러스터 내 최강 쌍이 floor 미만이면(동일인 증거 부재) 남남 부착으로 보고 축출. 둘 중 하나라도 0이면 비활성.
#CLUSTER_EVICT_GRAY_CEILING=0.46
#CLUSTER_EVICT_FACEPAIR_FLOOR=0.45
#CLUSTER_BLOB_PROMOTE_SIMILARITY=0.45
#CLUSTER_BLOB_PROMOTE_FLOOR=0.4
# 라우팅 정책: 주 인물 얼굴 2명+ 사진을 매칭 여부와 무관하게 공용 앨범에도 노출(인물 앨범과 중복, feature-spec §6.2).
# false면 구 정책(전원 미매칭 2+만 공용). Spring/앱이 새 common_album 의미를 감당할 때까지 false로 배포.
#CLUSTER_GROUP_PHOTO_TO_COMMON=true
# 매칭 사진의 주 인물 미매칭 얼굴을 uncertain("분류가 어려워요")에도 노출 — 미등록 인물의 수동 편입 진입점(feature-spec §6.2).
# false면 구 정책(매칭 얼굴이 하나라도 있으면 uncertain 제외 — 인물 앨범 우선 배타)
#CLUSTER_UNMATCHED_MAIN_TO_UNCERTAIN=true
# 주 인물 자격 — 사진 최대 얼굴 폭 대비 이 비율 미만은 지나가는 행인으로 보고 카운트 제외(ADR 022 규칙). 0=전체 얼굴 카운트
#CLUSTER_COMMON_MAIN_FACE_RATIO=0.5
# 실인물 자격 — 미배정 얼굴이 event 내 어떤 얼굴과도 유사도가 이 값 미만이면 오검출(털·사물)로 보고 카운트 제외(ADR 025). 0=비활성
#CLUSTER_COMMON_FACE_MIN_SIMILARITY=0.185
# 이중 검출 붕괴 — 같은 사진의 두 얼굴 행이 이 값 이상 닮으면 한 얼굴의 파편 박스 2개로 보고 한 명으로
# 센다(ADR 027) — 1인 셀피가 "주 인물 2명 단체"로 공용 앨범에 노출되던 문제. 0=비활성
#CLUSTER_COMMON_DUPLICATE_FACE_SIMILARITY=0.95
# 근중복 행 붕괴 (ADR 029) — 재업로드·유령 행 복제를 재군집 전에 대표 1행으로 접는다. 0=비활성
#CLUSTER_DUPLICATE_COLLAPSE_SIMILARITY=0.985
# uncertain 품질 원인 판정 (CHMO-404) — 앱이 "분류가 어려워요" 화면에 설명·재업로드 안내를 띄우는 근거.
# 주 얼굴이 이 px 미만이면 small_faces, 그중 원본 긴 변이 아래 값 미만이면 low_resolution("원본으로 다시")도.
# 실측 근거: 얼굴폭 매칭 무릎 ~100px, 단체사진 얼굴 rel_w ~5%라 100px엔 긴 변 ~2000px 필요. small_face_px=0이면 기능 전체 비활성
#CLUSTER_UNCERTAIN_SMALL_FACE_PX=100
#CLUSTER_UNCERTAIN_LOW_RES_LONG_SIDE=2000   # 0이면 low_resolution 원인만 비활성(small_faces는 유지)

# ── 입력 품질 교정 (선택 — 2026-07-14 리뷰: 정렬 안티에일리어싱 + 랜드마크 2단계 정제) ──
# 같은 얼굴 임베딩이 흔들리던 파이프라인 노이즈를 잡는 교정 토글. 운영 이슈 시 여기서 끈다.
#ALIGN_ANTIALIAS=true
#DETECT_MAX_SIDE=2000
#DETECT_REFINE_LANDMARKS=true
#DETECT_REFINE_NORM_FACE_WIDTH=224
#DETECT_REFINE_MARGIN_RATIO=0.75
# 배경 인물 필터 (ADR-013): 얼굴 bbox 폭이 이미지 긴 변의 2.5% 미만이면 검출 단계에서 버린다 —
# 멀리 배경에 찍힌 행인이 반복 등장해 앨범을 만드는 것 방지. 0 = 비활성.
#DETECT_MIN_FACE_REL_WIDTH=0.025
# 대형 오검출 결합 필터 (ADR-015): 얼굴 score가 이 값 미만 AND 종횡비(폭/높이)가 아래 값 미만이면
# 검출 단계에서 버린다 — 팔짱 낀 팔·조형물 등 진짜 얼굴 크기의 오검출 제거. 둘 중 하나라도 0이면 비활성.
#DETECT_FP_SCORE_THRESHOLD=0.78
#DETECT_FP_ASPECT_THRESHOLD=0.70
# 대형 근접 얼굴 재검출 회복 (ADR-017): rel_w(bbox폭/긴변)가 이 값 이상인 저score 얼굴을 정규 크기로
# 재검출해 재검출 score가 아래 값 이상이면 되살린다 — YuNet이 초근접 대형 얼굴에 낮은 score를 줘
# 공통 사진첩으로 빠지던 문제. 둘 중 하나라도 0이면 비활성. (0.30→0.20 재보정, ADR-017 §재보정)
#DETECT_BIG_FACE_REL_WIDTH=0.20
#DETECT_BIG_FACE_REDETECT_SCORE=0.80
# 크기 인지형 confident 게이트 (ADR-028): 대형 얼굴(rel_w ≥ BIG_FACE_REL_WIDTH)은 confident 게이트를 이
# 값으로 올려 저score 구간을 회복 재검출로 재판정한다 — 손·종이 등 대형 오검출이 게이트 0.6을 턱걸이로
# 통과해 유령 앨범을 만들던 문제(event 115 손 브이포즈). 대형은 재검출이 실얼굴/오검출을 가르므로 손실
# 없이 FP만 떨어진다. 소형은 회복이 없어 미적용(기본 게이트 유지). 기본 게이트 0.6과 같게 두면 비활성.
#DETECT_BIG_FACE_CONFIDENT_SCORE=0.70
# 재검출 랜드마크 신뢰 임계 (ADR-023): 재검출 score가 이 값 이상이면 랜드마크 이동량 가드를 무시하고
# 재검출 랜드마크를 채택한다 — 초대형 얼굴은 bbox가 파편이라 올바른 교정도 가드에 걸려 깨진 랜드마크가
# 유지되고, 그 임베딩이 공통 사진첩 유출·유령 앨범을 만들던 문제. 0 = 비활성(종전 가드만).
#DETECT_REFINE_TRUST_REDETECT_SCORE=0.80
# confident 파편 디둡 (ADR-027): 초대형 얼굴의 파편 박스 2개가 둘 다 score 게이트를 통과하면 한 사람이
# 두 명으로 검출된다 — 정제 랜드마크 중심거리가 이 비율×얼굴폭 미만인 대형(>REFINE_NORM) 쌍은 score
# 최상 박스만 남긴다. 0 = 비활성.
#DETECT_CONFIDENT_DEDUP_LANDMARK_RATIO=0.10

# ── 품질 게이트 임계값 (선택 — 눈감음/흔들림. 기본값은 초기값이며 face-test 실측 보정 필요) ──
#QUALITY_BLUR_THRESHOLD=100.0
#QUALITY_WHOLE_IMAGE_BLUR_THRESHOLD=100.0
# 최대 얼굴 폭 대비 이 비율 미만인 얼굴은 배경 인물로 보고 blur 판정 제외 (아웃포커스 오탐 방지). 0 = 비활성.
#QUALITY_BLUR_MAIN_FACE_RATIO=0.5
# 얼굴 미검출 fallback의 방향성 블러 검출 (ADR 014) — 그라디언트 방향 쏠림이 임계 이상이고
# 정규화 variance가 상한 미만이면 흔들림. 쏠림 임계 0 = 비활성.
#QUALITY_SHAKE_COHERENCE_THRESHOLD=0.35
#QUALITY_SHAKE_MAX_NORM_VARIANCE=60.0
# variance 흔들림 판정의 재확인 게이트 — 전체 이미지 방향 쏠림이 이 값 미만이면 손떨림이 아니라
# 원판이 소프트한 사진(옛날 인화 재촬영)으로 보고 해제 (event 50 실측). 0 = 비활성.
#QUALITY_SHAKE_COHERENCE_FLOOR=0.35
# 게이트 면제(fallback 한정) — 전체 variance가 이 값 미만이면 잔결 붕괴라 쏠림과 무관하게 흔들림
# 확정. 고스팅형 손떨림은 쏠림이 낮게 나온다 (event 55 실측). 0 = 비활성.
#QUALITY_WHOLE_IMAGE_COLLAPSE_VARIANCE=40.0
# 붕괴 면제의 얼굴 경로 확장 (ADR 018 §보강 2) — blurry 얼굴 폭이 긴 변 대비 이 비율 이상(대형 주
# 인물)이면 얼굴 경로에서도 위 붕괴 면제를 적용. 고스팅 대형 셀피가 검출 회복으로 얼굴 경로에 빠져
# 게이트에 오해제되던 문제 (event 64 실측). 0 = 비활성.
#QUALITY_COLLAPSE_FACE_REL_WIDTH=0.22
# 붕괴 면제의 얼굴 레벨 버전 (ADR 018 §보강 3) — blurry 얼굴의 최저 face_var가 이 값 미만이면 얼굴
# 잔결 붕괴라 쏠림과 무관하게 흔들림 확정. 소형 얼굴 등방성 손떨림이 위 두 면제를 다 비켜가던
# 사각지대 해소 (test9 흔들린 단체샷 실측, 빈 구간 [5.4, 10.0]). 0 = 비활성.
#QUALITY_FACE_VAR_COLLAPSE_FLOOR=7.0
#QUALITY_EYE_CLOSED_CONFIDENCE=0.85
#QUALITY_EYE_BOX_PX=24
# 눈감음 판정 자격 게이트 (ADR 019, CNN 폴백 경로에 적용) — bbox 짧은 변이 아래 값 미만이면 정보
# 부족(그림·옆얼굴 오탐), 눈/볼 밝기 비가 아래 상한 초과면 눈 자리가 피부가 아님(고글 반사·마스크
# 가림)으로 보고 미판정. 0 = 비활성.
#QUALITY_MIN_EYE_FACE_PX=64
#QUALITY_EYE_CHEEK_BRIGHTNESS_CEILING=1.4
# 눈감음 하이브리드 1차 — blendshape (ADR 021): min(blinkL, blinkR)가 임계 이상이면 눈감음, 얼굴
# presence가 바닥 미만이면 CNN 폴백. QUALITY_BLINK_THRESHOLD=0 이 롤백 스위치다 — blink 모델
# 로딩·판정을 통째로 끄고 순수 CNN(종전 동작)으로 복귀한다.
#QUALITY_BLINK_THRESHOLD=0.40
#QUALITY_BLINK_PRESENCE_FLOOR=0.5
# 눈감음 주 인물 규칙 — 최대 얼굴 폭 대비 이 비율 미만인 얼굴은 배경 인물로 보고 눈감음 판정에서
# 제외한다 (BLUR_MAIN_FACE_RATIO와 같은 논리, blink·CNN 공통 — event 69 행인 오탐). 0 = 비활성.
#QUALITY_EYE_MAIN_FACE_RATIO=0.5
# 눈감음 상대 크기 하한 — bbox 폭이 이미지 긴 변의 이 비율 미만이면 눈감음 판정에서 제외한다.
# EYE_MAIN_FACE_RATIO(최대 얼굴 대비)와 달리 이미지 대비라 프레임에서 작게 찍힌 원거리 얼굴을
# 거른다 — blink가 원거리 얼굴의 "아래 쳐다봄"을 감은 눈으로 오탐(event 99, ADR 026). 0 = 비활성.
#QUALITY_EYE_MIN_REL_WIDTH=0.08

# ── 인물 앨범 대표 얼굴 썸네일 (선택 — CHMO-335) ──────────────────────────────
# 재군집 후 클러스터마다 대표 얼굴(LOO centroid 유사도 최고 멤버)을 원본에서 crop해 EMBEDDINGS_BUCKET의
# {THUMBNAIL_PREFIX}{event_id}/{cluster_id}.jpg (= thumbnails/events/{event_id}/{cluster_id}.jpg, 원본·사진
# 썸네일과 같은 events/ 계층)에 덮어쓰고, 결과 메시지의 thumbnail_s3_key로 싣는다
# (Spring이 presigned URL 발급). THUMBNAIL_MAX_SIDE=0 이 롤백 스위치다 — 기능 전체(렌더·업로드·삭제)를
# 끄고 thumbnail_s3_key가 항상 null인 종전 결과로 복귀한다.
#THUMBNAIL_MAX_SIDE=256
#THUMBNAIL_JPEG_QUALITY=85
# 얼굴 bbox를 중심 기준 이 배율로 확장해 crop한다 — 딱 맞는 crop은 답답해 여백을 준다.
#THUMBNAIL_BBOX_SCALE=1.4
#THUMBNAIL_PREFIX=thumbnails/events/

# ── Rekognition uncertain 재판정 (선택 — ADR-030, 2026-07-23 실측 리뷰) ─────────
# 미배정(uncertain) 얼굴을 AuraFace 유사도 상위 top_k개 앨범 대표와 CompareFaces로 재판정한다:
# 최고점 ≥ AUTO면 자동 편입(must-link 기록), [SUGGEST, AUTO)면 결과 메시지에 제안(suggestions),
# FRAGMENT 이상 복수 매칭이면 파편 앨범 힌트(로그). (face, 대표) 쌍 점수는
# {REJUDGE_SCORES_PREFIX}{event_id}.json 에 캐싱돼 재군집·보정 때 재과금이 없다.
# 기본 ON(CHMO-420 활성화) — REJUDGE_ENABLED=false 가 롤백 스위치(재판정·캐시·suggestions 전부
# 끄고 종전 동작 복귀). 운영 전제 조건(AWS AI 학습 opt-out·처리방침 위탁 문구·워커 IAM
# rekognition:CompareFaces 권한)은 ADR 030 §활성화 게이트 참조 — 미충족 환경은 false로 배포.
# 비용 $0.001/호출 (정상 이벤트 ~9회 ≈ 1.3원, job당 상한 아래 MAX_CALLS).
#REJUDGE_ENABLED=true
#REJUDGE_AUTO_ASSIGN_SIMILARITY=90.0   # 실측 실용 권장값 — 보수 운영은 95 (전수 정답 임계)
#REJUDGE_SUGGEST_SIMILARITY=85.0       # 미만은 오답 대역(82~84 남매·타인 아기 실존) — 판정 보류
#REJUDGE_FRAGMENT_SIMILARITY=95.0
#REJUDGE_TOP_K=3
#REJUDGE_MAX_CALLS_PER_JOB=150         # 오염 이벤트의 비용 폭주 안전판
# crop 파라미터는 실측과 파리티가 계약 (bbox+0.25 여백·JPEG q92·축소 없음) — 바꾸면 임계 근거가 무효
#REJUDGE_CROP_MARGIN=0.25
#REJUDGE_CROP_JPEG_QUALITY=92
#REJUDGE_SCORES_PREFIX=rekognition-scores/

# ── Rekognition 앨범 쌍 병합 재판정 (선택 — ADR-031, 2026-07-24 실측 리뷰) ───────
# 같은 인물이 두 앨범으로 갈라진 것을 회수한다: 로컬 게이트가 거절한 회색지대 앨범 쌍
# (centroid ≥ PROBE_FLOOR)을 앨범당 대표 REPS장씩 K×K로 비교해, 전원이 MERGE_SIMILARITY 이상이고
# 산포(max−min)가 MAX_SPREAD 이하일 때만 병합한다. 3개 이상이 합쳐질 땐 컴포넌트의 모든 쌍이
# 통과해야 한다(체인 융합 차단). 같은 사진 공존·사용자 split 쌍은 호출 전에 탈락한다.
# 스위치가 2단이다: ENABLED가 호출·판정·로그, APPLY가 실제 병합 반영이다. 기본 ON(2026-07-24 활성화) —
# REJUDGE_PAIR_APPLY=false 가 1단 롤백(판정 로그만, 파티션 불변·비용은 계속 발생),
# REJUDGE_PAIR_ENABLED=false 가 완전 롤백(호출 0회, 종전 동작). 실 이벤트 회귀는 미수행이라 첫
# 실사용자 이벤트가 사실상 첫 실측이다 — 오병합이 보이면 APPLY부터 내리고 로그의 K×K 점수·산포로
# 원인을 본다. 점수 캐시·crop·IAM 권한(rekognition:CompareFaces)은 위 얼굴 단위 재판정과 공유한다.
# 비용: 이벤트당 최초 $0.19 + 월 $1.48(아이 20명 실측 기준) — 앨범 쌍 수는 인물 수의 제곱으로 는다.
#REJUDGE_PAIR_ENABLED=true
#REJUDGE_PAIR_APPLY=true
#REJUDGE_PAIR_PROBE_FLOOR=0.35          # 비용 통제용 바닥 (정확도 판정 아님 — 실측 회수분 최저 0.438)
#REJUDGE_PAIR_MERGE_SIMILARITY=90.0     # 통과분이 전부 98점 이상이라 95와 결과 동일 (방어선은 전원 합의)
#REJUDGE_PAIR_MAX_SPREAD=5.0            # 통과 13쌍 산포 0.0~1.9 vs 타인 대조군 15.0~98.4
#REJUDGE_PAIR_REPS=2                    # 앨범당 대표 수 K (쌍당 K² 호출). K=1(argmax)은 실측 기각
#REJUDGE_PAIR_MAX_CALLS_PER_JOB=200     # 인물 수 제곱 증가의 비용 안전판

# ── 비인간 얼굴 게이트 — 인형·조형물 오검출 (선택 — ADR-032, 2026-07-24 실측 스윕) ──
# 인형·조형물이 사람으로 잡혀 앨범을 만들거나(실 event 139 몽치치 3장 앨범) uncertain으로 새는 것을
# 막는다. 얼굴 crop에 DetectLabels 1콜 → Sculpture|Statue ≥ SCULPTURE면 즉시 강등, Doll|Toy ≥ DOLL이면
# DetectFaces 2콜째가 얼굴 0개일 때만 강등한다 — 2신호 AND가 필수(미검출 단독 규칙은 실제 아이
# 4/17(24%)을 오거부, 실측). 강등 얼굴은 npz nonhuman_face_ids에 기록돼 재군집 입력에서 빠지고,
# 전량 강등 사진은 공용 앨범으로 간다. 사용자 보정이 강등 얼굴을 건드리면 해제된다(영구 복구).
# 기본 ON(사용자 결정 — 인형 4종·조형물 2종 실측, 3D 피규어·사실적 회화·마네킹은 미측정이라 첫
# 실사용자 이벤트가 첫 실측) — NONHUMAN_GATE_ENABLED=false 가 롤백 스위치이며 npz에 남은 강등
# 기록도 무시돼 강등 얼굴이 전부 되살아난다. 판정 캐시는 {NONHUMAN_VERDICTS_PREFIX}{event_id}.json.
# 운영 전제 조건은 ADR 030과 동일 + 워커 IAM에 rekognition:DetectLabels·DetectFaces —
# 권한이 없으면 best-effort 폴백으로 종전 동작 + 경고 로그만 남는다(무음으로 꺼진 상태가 된다).
# 비용: 얼굴당 최대 2콜 × $0.001, job당 상한 MAX_CALLS.
#NONHUMAN_GATE_ENABLED=true
#NONHUMAN_DOLL_CONFIDENCE=90.0          # Doll|Toy 임계 (인형 실측 96.9~99.7 vs 실인물 오탐 0/54)
#NONHUMAN_SCULPTURE_CONFIDENCE=70.0     # Sculpture|Statue 임계 (조형물 실측 77.1~92.5 vs 오탐 0/55)
#NONHUMAN_LABEL_MIN_CONFIDENCE=50.0     # DetectLabels MinConfidence — 응답 하한 (판정 임계와 별개)
#NONHUMAN_CLUSTER_PROBE_FACES=3         # 신규 앨범 후보당 판정 얼굴 수 (폭 상위) — 과반 강등의 분모
#NONHUMAN_MAX_CALLS_PER_JOB=100         # 비용 폭주 안전판 (DetectLabels+DetectFaces 합산)
#NONHUMAN_VERDICTS_PREFIX=nonhuman-verdicts/

#LOG_LEVEL=INFO
